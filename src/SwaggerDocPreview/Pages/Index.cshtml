@page "/"

@model SwaggerDocPreview.Pages.IndexModel
@{
    var currentPath = (HttpContext.Request.Path.Value ?? "/swagger").TrimEnd('/').ToLowerInvariant();
    if (string.IsNullOrWhiteSpace(currentPath))
    {
        currentPath = "/swagger";
    }

    var pageTitle = "Swagger JSON Preview & Export Tool - Export OpenAPI Docs to Markdown, DOCX, PDF";
    var pageDescription = "Upload or paste Swagger/OpenAPI JSON, preview it with Swagger UI, and export API documentation to Markdown, DOCX, PDF, or ZIP online.";
    var pageHeading = "Swagger JSON Preview & Export Tool";
    var pageSummary = "Upload or paste Swagger/OpenAPI JSON, preview it with Swagger UI, and export API documentation.";

    switch (currentPath)
    {
        case "/swagger-json-preview":
            pageTitle = "Swagger JSON Preview Tool - Preview OpenAPI JSON Online";
            pageDescription = "Upload or paste Swagger/OpenAPI JSON and preview API documentation online with Swagger UI.";
            pageHeading = "Swagger JSON Preview Tool";
            pageSummary = "Upload or paste Swagger/OpenAPI JSON, validate it, and preview the API documentation with Swagger UI.";
            break;
        case "/swagger-json-export":
            pageTitle = "Swagger JSON Export Tool - Export API Docs to Markdown, DOCX, PDF";
            pageDescription = "Convert Swagger JSON into Markdown, DOCX, PDF, or ZIP documentation files online.";
            pageHeading = "Swagger JSON Export Tool";
            pageSummary = "Convert Swagger JSON into shareable API documentation formats including Markdown, DOCX, PDF, and ZIP.";
            break;
        case "/openapi-json-export":
            pageTitle = "OpenAPI JSON Export Tool - Export OpenAPI Docs to Markdown, DOCX, PDF";
            pageDescription = "Upload OpenAPI 3.x JSON, preview the API, and export documentation to Markdown, DOCX, PDF, or ZIP.";
            pageHeading = "OpenAPI JSON Export Tool";
            pageSummary = "Preview OpenAPI 3.x JSON and export generated API documentation for developers, testers, and product teams.";
            break;
        case "/swagger-to-markdown":
            pageTitle = "Swagger to Markdown Converter - Export OpenAPI JSON to Markdown";
            pageDescription = "Convert Swagger/OpenAPI JSON into Markdown API documentation online.";
            pageHeading = "Swagger to Markdown Converter";
            pageSummary = "Generate clean Markdown API documentation from Swagger or OpenAPI JSON.";
            break;
        case "/swagger-to-pdf":
            pageTitle = "Swagger to PDF Converter - Export OpenAPI Documentation to PDF";
            pageDescription = "Convert Swagger/OpenAPI JSON into PDF API documentation online.";
            pageHeading = "Swagger to PDF Converter";
            pageSummary = "Export Swagger or OpenAPI JSON as PDF documentation for sharing, review, and archive workflows.";
            break;
        case "/swagger-to-docx":
            pageTitle = "Swagger to DOCX Converter - Export OpenAPI Documentation to Word";
            pageDescription = "Convert Swagger/OpenAPI JSON into editable DOCX Word API documentation online.";
            pageHeading = "Swagger to DOCX Converter";
            pageSummary = "Create editable Word DOCX API documentation from Swagger or OpenAPI JSON.";
            break;
        case "/zh/swagger":
            pageTitle = "Swagger JSON 在线预览和导出工具 - 支持 OpenAPI 转 Markdown、DOCX、PDF";
            pageDescription = "在线上传或粘贴 Swagger/OpenAPI JSON，预览接口文档，并导出 Markdown、DOCX、PDF 或 ZIP 文件。";
            pageHeading = "Swagger JSON 在线预览和导出工具";
            pageSummary = "上传或粘贴 Swagger/OpenAPI JSON，在线预览接口文档，并导出 Markdown、DOCX、PDF 或 ZIP 文件。";
            break;
        case "/zh/swagger-json-export":
            pageTitle = "Swagger JSON 导出工具 - 在线导出 Markdown、DOCX、PDF";
            pageDescription = "在线将 Swagger JSON 转换为 Markdown、DOCX、PDF 或 ZIP 接口文档。";
            pageHeading = "Swagger JSON 导出工具";
            pageSummary = "将 Swagger JSON 在线转换为 Markdown、DOCX、PDF 或 ZIP，方便团队共享接口文档。";
            break;
        case "/zh/openapi-json-export":
            pageTitle = "OpenAPI JSON 导出工具 - 在线生成 Markdown、DOCX、PDF 文档";
            pageDescription = "在线上传 OpenAPI 3.x JSON，预览接口并导出 Markdown、DOCX、PDF 或 ZIP 文件。";
            pageHeading = "OpenAPI JSON 导出工具";
            pageSummary = "上传 OpenAPI 3.x JSON，在线预览接口文档，并生成可分享的多格式 API 文档。";
            break;
        case "/zh/swagger-to-pdf":
            pageTitle = "Swagger 转 PDF 工具 - 在线导出 API 文档 PDF";
            pageDescription = "在线将 Swagger/OpenAPI JSON 转换为 PDF API 文档。";
            pageHeading = "Swagger 转 PDF 工具";
            pageSummary = "把 Swagger/OpenAPI JSON 在线转换为 PDF 文档，适合归档、评审和对外共享。";
            break;
    }

    ViewData["Title"] = pageTitle;
    ViewData["Description"] = pageDescription;
    ViewData["CanonicalUrl"] = $"https://swagger.sunmoon.cool{currentPath}";
    var hasPreview = !string.IsNullOrWhiteSpace(Model.PreviewId);
    var sourceName = string.IsNullOrWhiteSpace(Model.SourceName) ? "swagger.json" : Model.SourceName;
}

<section class="hero">
    <div>
        <h1>@pageHeading</h1>
        <p>@pageSummary</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="status-banner status-banner-error">
        <span class="status-banner-icon" aria-hidden="true">!</span>
        <span>@Model.ErrorMessage</span>
    </div>
}

<form method="post" action="/swagger/preview" enctype="multipart/form-data" class="panel stack-lg" id="preview-form">
    <div class="section-heading">
        <h2>1. Input Swagger / OpenAPI JSON</h2>
    </div>

    <div class="input-grid">
        <div class="upload-panel">
            <label class="field-label" for="swagger-file">Upload JSON File</label>
            <label class="file-dropzone" for="swagger-file" id="file-dropzone">
                <input id="swagger-file" asp-for="SwaggerFile" accept=".json,application/json" />
                <span class="file-dropzone-button">
                    <svg viewBox="0 0 20 20" aria-hidden="true">
                        <path d="M4.5 2.5h7l4 4V16a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 3.5 16V4A1.5 1.5 0 0 1 5 2.5h-.5Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.6" />
                        <path d="M11.5 2.8V6.5H15.2" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.6" />
                    </svg>
                    <span>Choose File</span>
                </span>
                <span class="file-dropzone-name" id="file-name">@sourceName</span>
                <span class="file-dropzone-state" id="file-state" aria-hidden="true">
                    <svg viewBox="0 0 20 20">
                        <circle cx="10" cy="10" r="8" fill="currentColor" opacity="0.18"></circle>
                        <path d="M6 10.3 8.6 13 14 7.8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.9"></path>
                    </svg>
                </span>
            </label>
            <p class="field-hint">Only <code>.json</code> files are supported (Swagger 2.0 / OpenAPI 3.x)</p>
            <input type="hidden" name="sourceName" id="source-name" value="@sourceName" />
        </div>

        <div class="editor-panel">
            <label class="field-label" for="swagger-json">Or Paste JSON</label>
            <div class="json-editor" id="json-editor">
                <pre class="json-editor-lines" id="json-lines" aria-hidden="true"></pre>
                <textarea id="swagger-json" asp-for="SwaggerJson" spellcheck="false" autocomplete="off"></textarea>
            </div>
        </div>
    </div>

    <div class="actions-row">
        <button type="submit" class="button button-primary">
            <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="M2.5 10s2.8-4.8 7.5-4.8S17.5 10 17.5 10s-2.8 4.8-7.5 4.8S2.5 10 2.5 10Z" fill="none" stroke="currentColor" stroke-width="1.7"></path>
                <circle cx="10" cy="10" r="2.4" fill="none" stroke="currentColor" stroke-width="1.7"></circle>
            </svg>
            <span>Preview</span>
        </button>
        <button type="button" class="button button-secondary" id="clear-button">
            <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="M5.4 6.2h9.2M8 6.2V4.8a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1.4M6.6 6.2l.7 9a1 1 0 0 0 1 .9h3.4a1 1 0 0 0 1-.9l.7-9" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7"></path>
            </svg>
            <span>Clear</span>
        </button>
    </div>
</form>

<section class="panel stack-lg">
    <div class="section-heading">
        <h2>2. Document Actions</h2>
    </div>

    <div class="document-grid">
        <dl class="doc-meta" id="doc-meta">
            <div>
                <dt>Source File:</dt>
                <dd id="meta-source">@sourceName</dd>
            </div>
            <div>
                <dt>Title:</dt>
                <dd id="meta-title">Waiting for preview</dd>
            </div>
            <div>
                <dt>Version:</dt>
                <dd id="meta-version">-</dd>
            </div>
            <div>
                <dt>Status:</dt>
                <dd>
                    <span class="status-pill @(hasPreview ? "status-pill-success" : "status-pill-muted")" id="meta-status">
                        @(hasPreview ? "Valid OpenAPI JSON" : "Preview required")
                    </span>
                </dd>
            </div>
        </dl>

        <div class="download-grid">
            <form method="post" action="/swagger/download" target="download-frame" class="download-card-form js-download-form">
                <input type="hidden" name="previewId" value="@Model.PreviewId" />
                <input type="hidden" name="format" value="md" />
                <button type="submit" class="download-card" @(hasPreview ? null : "disabled")>
                    <span class="download-icon download-icon-markdown">M</span>
                    <span class="download-copy">
                        <strong>Download Markdown</strong>
                        <small>(.md)</small>
                    </span>
                </button>
            </form>

            <form method="post" action="/swagger/download" target="download-frame" class="download-card-form js-download-form">
                <input type="hidden" name="previewId" value="@Model.PreviewId" />
                <input type="hidden" name="format" value="docx" />
                <button type="submit" class="download-card" @(hasPreview ? null : "disabled")>
                    <span class="download-icon download-icon-docx">W</span>
                    <span class="download-copy">
                        <strong>Download DOCX</strong>
                        <small>(.docx)</small>
                    </span>
                </button>
            </form>

            <form method="post" action="/swagger/download" target="download-frame" class="download-card-form js-download-form">
                <input type="hidden" name="previewId" value="@Model.PreviewId" />
                <input type="hidden" name="format" value="pdf" />
                <button type="submit" class="download-card" @(hasPreview ? null : "disabled")>
                    <span class="download-icon download-icon-pdf">PDF</span>
                    <span class="download-copy">
                        <strong>Download PDF</strong>
                        <small>(.pdf)</small>
                    </span>
                </button>
            </form>

            <form method="post" action="/swagger/download-all" target="download-frame" class="download-card-form js-download-form">
                <input type="hidden" name="previewId" value="@Model.PreviewId" />
                <button type="submit" class="download-card" @(hasPreview ? null : "disabled")>
                    <span class="download-icon download-icon-all">ZIP</span>
                    <span class="download-copy">
                        <strong>Download All</strong>
                        <small>(.zip)</small>
                    </span>
                </button>
            </form>
        </div>
    </div>

    <p class="section-note">"Download All" will generate a ZIP file containing <code>.md</code>, <code>.docx</code>, and <code>.pdf</code> files.</p>
</section>

<section class="panel stack-lg" id="preview-panel">
    <div class="section-heading">
        <h2>3. Swagger UI Preview</h2>
        <button type="button" class="expand-button" id="expand-preview">
            <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="M7.5 3.5h-4v4M3.5 3.5l5 5M12.5 16.5h4v-4M16.5 16.5l-5-5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7"></path>
            </svg>
            <span>Expand</span>
        </button>
    </div>

    @if (hasPreview)
    {
        <div class="swagger-preview-shell">
            <div id="swagger-ui"></div>
        </div>
    }
    else
    {
        <div class="empty-preview">
            <div class="empty-preview-icon">{ }</div>
            <div>
                <h3>Swagger UI will appear here</h3>
                <p>Upload or paste a valid Swagger/OpenAPI JSON document, then click <strong>Preview</strong>.</p>
            </div>
        </div>
    }
</section>

<section class="seo-content" aria-labelledby="swagger-export-tool-heading">
    <div class="seo-content-grid">
        <div class="seo-copy">
            <h2 id="swagger-export-tool-heading">What can this Swagger export tool do?</h2>
            <p>
                This tool allows developers to upload or paste Swagger/OpenAPI JSON, preview API documentation with Swagger UI,
                and export the documentation as Markdown, DOCX, PDF, or ZIP files.
            </p>
        </div>
        <div class="seo-copy">
            <h2>这个 Swagger 导出工具可以做什么？</h2>
            <p>
                你可以上传或粘贴 Swagger/OpenAPI JSON，在线预览接口文档，并将接口文档导出为 Markdown、DOCX、PDF 或 ZIP 文件。
            </p>
        </div>
    </div>

    <div class="seo-list-grid">
        <section class="seo-list-card">
            <h2>Supported formats</h2>
            <ul>
                <li>Swagger 2.0 JSON</li>
                <li>OpenAPI 3.x JSON</li>
                <li>Markdown export</li>
                <li>DOCX export</li>
                <li>PDF export</li>
                <li>ZIP export</li>
            </ul>
        </section>

        <section class="seo-list-card">
            <h2>Common use cases</h2>
            <ul>
                <li>Generate API documentation from Swagger JSON</li>
                <li>Convert OpenAPI JSON to Markdown</li>
                <li>Export Swagger documentation to PDF</li>
                <li>Share API documentation with non-technical users</li>
            </ul>
        </section>

        <section class="seo-list-card">
            <h2>支持的格式</h2>
            <ul>
                <li>Swagger 2.0 JSON</li>
                <li>OpenAPI 3.x JSON</li>
                <li>Markdown 文档导出</li>
                <li>DOCX 文档导出</li>
                <li>PDF 文档导出</li>
                <li>ZIP 打包下载</li>
            </ul>
        </section>
    </div>
</section>

<div class="loading-overlay" id="download-loading-overlay" aria-live="polite" aria-hidden="true">
    <div class="loading-dialog" role="status">
        <span class="loading-spinner" aria-hidden="true"></span>
        <strong>Generating documentation</strong>
        <span>Please wait while the file is prepared.</span>
    </div>
</div>
<iframe name="download-frame" class="download-frame" title="Download target"></iframe>

@section Styles
{
    @if (hasPreview)
    {
        <link rel="stylesheet" href="https://unpkg.com/swagger-ui-dist@5.17.14/swagger-ui.css" />
    }
}

@section Scripts
{
    @if (hasPreview)
    {
        <script src="https://unpkg.com/swagger-ui-dist@5.17.14/swagger-ui-bundle.js"></script>
    }

    <script>
        (() => {
            const sourceNameInput = document.getElementById("source-name");
            const fileInput = document.getElementById("swagger-file");
            const fileName = document.getElementById("file-name");
            const fileDropzone = document.getElementById("file-dropzone");
            const textArea = document.getElementById("swagger-json");
            const lineNumbers = document.getElementById("json-lines");
            const clearButton = document.getElementById("clear-button");
            const expandButton = document.getElementById("expand-preview");
            const previewPanel = document.getElementById("preview-panel");
            const metaTitle = document.getElementById("meta-title");
            const metaVersion = document.getElementById("meta-version");
            const metaSource = document.getElementById("meta-source");
            const metaStatus = document.getElementById("meta-status");
            const downloadForms = document.querySelectorAll(".js-download-form");
            const loadingOverlay = document.getElementById("download-loading-overlay");
            let loadingTimer = null;

            const updateLineNumbers = () => {
                const totalLines = Math.max(1, textArea.value.split("\n").length);
                lineNumbers.textContent = Array.from({ length: totalLines }, (_, index) => index + 1).join("\n");
                lineNumbers.scrollTop = textArea.scrollTop;
            };

            const parseDocumentMeta = () => {
                const fallbackSource = sourceNameInput.value || "swagger.json";
                metaSource.textContent = fallbackSource;

                try {
                    const parsed = JSON.parse(textArea.value);
                    const info = parsed.info || {};
                    metaTitle.textContent = info.title || "Untitled API";
                    metaVersion.textContent = info.version || "-";

                    if (parsed.paths && Object.keys(parsed.paths).length > 0) {
                        metaStatus.textContent = "Valid OpenAPI JSON";
                        metaStatus.classList.add("status-pill-success");
                        metaStatus.classList.remove("status-pill-muted");
                    } else {
                        metaStatus.textContent = "JSON loaded";
                        metaStatus.classList.remove("status-pill-success");
                        metaStatus.classList.add("status-pill-muted");
                    }
                } catch {
                    metaTitle.textContent = "Waiting for preview";
                    metaVersion.textContent = "-";
                    metaStatus.textContent = "Invalid JSON";
                    metaStatus.classList.remove("status-pill-success");
                    metaStatus.classList.add("status-pill-muted");
                }
            };

            if (fileInput) {
                fileInput.addEventListener("change", () => {
                    const file = fileInput.files && fileInput.files[0];
                    if (!file) {
                        return;
                    }

                    fileName.textContent = file.name;
                    sourceNameInput.value = file.name;
                    metaSource.textContent = file.name;
                    fileDropzone.classList.add("has-file");

                    const reader = new FileReader();
                    reader.onload = () => {
                        if (typeof reader.result === "string") {
                            textArea.value = reader.result;
                            updateLineNumbers();
                            parseDocumentMeta();
                        }
                    };

                    reader.readAsText(file);
                });
            }

            textArea.addEventListener("input", () => {
                updateLineNumbers();
                parseDocumentMeta();
            });

            textArea.addEventListener("scroll", () => {
                lineNumbers.scrollTop = textArea.scrollTop;
            });

            clearButton.addEventListener("click", () => {
                window.location.href = "/swagger";
            });

            expandButton.addEventListener("click", () => {
                previewPanel.classList.toggle("is-expanded");
            });

            const setDownloadLoading = (isLoading) => {
                document.body.classList.toggle("is-download-loading", isLoading);
                loadingOverlay.setAttribute("aria-hidden", isLoading ? "false" : "true");

                document.querySelectorAll("button, input:not([type='hidden']), textarea").forEach((element) => {
                    if (element.dataset.originallyDisabled === undefined) {
                        element.dataset.originallyDisabled = element.disabled ? "true" : "false";
                    }

                    element.disabled = isLoading || element.dataset.originallyDisabled === "true";

                    if (!isLoading) {
                        delete element.dataset.originallyDisabled;
                    }
                });
            };

            downloadForms.forEach((form) => {
                form.addEventListener("submit", () => {
                    window.clearTimeout(loadingTimer);
                    setDownloadLoading(true);

                    loadingTimer = window.setTimeout(() => {
                        setDownloadLoading(false);
                    }, 8000);
                });
            });

            updateLineNumbers();
            parseDocumentMeta();

            @if (hasPreview)
            {
                <text>
                window.ui = SwaggerUIBundle({
                    dom_id: "#swagger-ui",
                    url: "/swagger/spec/@(Model.PreviewId).json",
                    deepLinking: true,
                    displayRequestDuration: true,
                    docExpansion: "list",
                    filter: true,
                    persistAuthorization: true
                });
                </text>
            }
        })();
    </script>
}
