@page "/swagger"
@model SwaggerDocPreview.Pages.IndexModel
@{
    ViewData["Title"] = "Swagger Doc Preview";
    var hasPreview = !string.IsNullOrWhiteSpace(Model.PreviewId);
    var sourceName = string.IsNullOrWhiteSpace(Model.SourceName) ? "swagger.json" : Model.SourceName;
}

<section class="hero">
    <div>
        <h1>Swagger Doc Preview</h1>
        <p>Upload or paste Swagger/OpenAPI JSON, preview it with Swagger UI, and export documentation.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="status-banner status-banner-error">
        <span class="status-banner-icon" aria-hidden="true">!</span>
        <span>@Model.ErrorMessage</span>
    </div>
}

<form method="post" action="/swagger/preview" enctype="multipart/form-data" class="panel stack-lg" id="preview-form">
    <div class="section-heading">
        <h2>1. Input Swagger / OpenAPI JSON</h2>
    </div>

    <div class="input-grid">
        <div class="upload-panel">
            <label class="field-label" for="swagger-file">Upload JSON File</label>
            <label class="file-dropzone" for="swagger-file" id="file-dropzone">
                <input id="swagger-file" asp-for="SwaggerFile" accept=".json,application/json" />
                <span class="file-dropzone-button">
                    <svg viewBox="0 0 20 20" aria-hidden="true">
                        <path d="M4.5 2.5h7l4 4V16a1.5 1.5 0 0 1-1.5 1.5h-9A1.5 1.5 0 0 1 3.5 16V4A1.5 1.5 0 0 1 5 2.5h-.5Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.6" />
                        <path d="M11.5 2.8V6.5H15.2" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.6" />
                    </svg>
                    <span>Choose File</span>
                </span>
                <span class="file-dropzone-name" id="file-name">@sourceName</span>
                <span class="file-dropzone-state" id="file-state" aria-hidden="true">
                    <svg viewBox="0 0 20 20">
                        <circle cx="10" cy="10" r="8" fill="currentColor" opacity="0.18"></circle>
                        <path d="M6 10.3 8.6 13 14 7.8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.9"></path>
                    </svg>
                </span>
            </label>
            <p class="field-hint">Only <code>.json</code> files are supported (Swagger 2.0 / OpenAPI 3.x)</p>
            <input type="hidden" name="sourceName" id="source-name" value="@sourceName" />
        </div>

        <div class="editor-panel">
            <label class="field-label" for="swagger-json">Or Paste JSON</label>
            <div class="json-editor" id="json-editor">
                <pre class="json-editor-lines" id="json-lines" aria-hidden="true"></pre>
                <textarea id="swagger-json" asp-for="SwaggerJson" spellcheck="false" autocomplete="off"></textarea>
            </div>
        </div>
    </div>

    <div class="actions-row">
        <button type="submit" class="button button-primary">
            <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="M2.5 10s2.8-4.8 7.5-4.8S17.5 10 17.5 10s-2.8 4.8-7.5 4.8S2.5 10 2.5 10Z" fill="none" stroke="currentColor" stroke-width="1.7"></path>
                <circle cx="10" cy="10" r="2.4" fill="none" stroke="currentColor" stroke-width="1.7"></circle>
            </svg>
            <span>Preview</span>
        </button>
        <button type="button" class="button button-secondary" id="clear-button">
            <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="M5.4 6.2h9.2M8 6.2V4.8a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v1.4M6.6 6.2l.7 9a1 1 0 0 0 1 .9h3.4a1 1 0 0 0 1-.9l.7-9" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7"></path>
            </svg>
            <span>Clear</span>
        </button>
    </div>
</form>

<section class="panel stack-lg">
    <div class="section-heading">
        <h2>2. Document Actions</h2>
    </div>

    <div class="document-grid">
        <dl class="doc-meta" id="doc-meta">
            <div>
                <dt>Source File:</dt>
                <dd id="meta-source">@sourceName</dd>
            </div>
            <div>
                <dt>Title:</dt>
                <dd id="meta-title">Waiting for preview</dd>
            </div>
            <div>
                <dt>Version:</dt>
                <dd id="meta-version">-</dd>
            </div>
            <div>
                <dt>Status:</dt>
                <dd>
                    <span class="status-pill @(hasPreview ? "status-pill-success" : "status-pill-muted")" id="meta-status">
                        @(hasPreview ? "Valid OpenAPI JSON" : "Preview required")
                    </span>
                </dd>
            </div>
        </dl>

        <div class="download-grid">
            <form method="post" action="/swagger/download" class="download-card-form">
                <input type="hidden" name="previewId" value="@Model.PreviewId" />
                <input type="hidden" name="format" value="md" />
                <button type="submit" class="download-card" @(hasPreview ? null : "disabled")>
                    <span class="download-icon download-icon-markdown">M</span>
                    <span class="download-copy">
                        <strong>Download Markdown</strong>
                        <small>(.md)</small>
                    </span>
                </button>
            </form>

            <form method="post" action="/swagger/download" class="download-card-form">
                <input type="hidden" name="previewId" value="@Model.PreviewId" />
                <input type="hidden" name="format" value="docx" />
                <button type="submit" class="download-card" @(hasPreview ? null : "disabled")>
                    <span class="download-icon download-icon-docx">W</span>
                    <span class="download-copy">
                        <strong>Download DOCX</strong>
                        <small>(.docx)</small>
                    </span>
                </button>
            </form>

            <form method="post" action="/swagger/download" class="download-card-form">
                <input type="hidden" name="previewId" value="@Model.PreviewId" />
                <input type="hidden" name="format" value="pdf" />
                <button type="submit" class="download-card" @(hasPreview ? null : "disabled")>
                    <span class="download-icon download-icon-pdf">PDF</span>
                    <span class="download-copy">
                        <strong>Download PDF</strong>
                        <small>(.pdf)</small>
                    </span>
                </button>
            </form>

            <form method="post" action="/swagger/download-all" class="download-card-form">
                <input type="hidden" name="previewId" value="@Model.PreviewId" />
                <button type="submit" class="download-card" @(hasPreview ? null : "disabled")>
                    <span class="download-icon download-icon-all">ZIP</span>
                    <span class="download-copy">
                        <strong>Download All</strong>
                        <small>(.zip)</small>
                    </span>
                </button>
            </form>
        </div>
    </div>

    <p class="section-note">"Download All" will generate a ZIP file containing <code>.md</code>, <code>.docx</code>, and <code>.pdf</code> files.</p>
</section>

<section class="panel stack-lg" id="preview-panel">
    <div class="section-heading">
        <h2>3. Swagger UI Preview</h2>
        <button type="button" class="expand-button" id="expand-preview">
            <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="M7.5 3.5h-4v4M3.5 3.5l5 5M12.5 16.5h4v-4M16.5 16.5l-5-5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7"></path>
            </svg>
            <span>Expand</span>
        </button>
    </div>

    @if (hasPreview)
    {
        <div class="swagger-preview-shell">
            <div id="swagger-ui"></div>
        </div>
    }
    else
    {
        <div class="empty-preview">
            <div class="empty-preview-icon">{ }</div>
            <div>
                <h3>Swagger UI will appear here</h3>
                <p>Upload or paste a valid Swagger/OpenAPI JSON document, then click <strong>Preview</strong>.</p>
            </div>
        </div>
    }
</section>

@section Styles
{
    @if (hasPreview)
    {
        <link rel="stylesheet" href="https://unpkg.com/swagger-ui-dist@5.17.14/swagger-ui.css" />
    }
}

@section Scripts
{
    @if (hasPreview)
    {
        <script src="https://unpkg.com/swagger-ui-dist@5.17.14/swagger-ui-bundle.js"></script>
    }

    <script>
        (() => {
            const sourceNameInput = document.getElementById("source-name");
            const fileInput = document.getElementById("swagger-file");
            const fileName = document.getElementById("file-name");
            const fileDropzone = document.getElementById("file-dropzone");
            const textArea = document.getElementById("swagger-json");
            const lineNumbers = document.getElementById("json-lines");
            const clearButton = document.getElementById("clear-button");
            const expandButton = document.getElementById("expand-preview");
            const previewPanel = document.getElementById("preview-panel");
            const metaTitle = document.getElementById("meta-title");
            const metaVersion = document.getElementById("meta-version");
            const metaSource = document.getElementById("meta-source");
            const metaStatus = document.getElementById("meta-status");

            const updateLineNumbers = () => {
                const totalLines = Math.max(1, textArea.value.split("\n").length);
                lineNumbers.textContent = Array.from({ length: totalLines }, (_, index) => index + 1).join("\n");
                lineNumbers.scrollTop = textArea.scrollTop;
            };

            const parseDocumentMeta = () => {
                const fallbackSource = sourceNameInput.value || "swagger.json";
                metaSource.textContent = fallbackSource;

                try {
                    const parsed = JSON.parse(textArea.value);
                    const info = parsed.info || {};
                    metaTitle.textContent = info.title || "Untitled API";
                    metaVersion.textContent = info.version || "-";

                    if (parsed.paths && Object.keys(parsed.paths).length > 0) {
                        metaStatus.textContent = "Valid OpenAPI JSON";
                        metaStatus.classList.add("status-pill-success");
                        metaStatus.classList.remove("status-pill-muted");
                    } else {
                        metaStatus.textContent = "JSON loaded";
                        metaStatus.classList.remove("status-pill-success");
                        metaStatus.classList.add("status-pill-muted");
                    }
                } catch {
                    metaTitle.textContent = "Waiting for preview";
                    metaVersion.textContent = "-";
                    metaStatus.textContent = "Invalid JSON";
                    metaStatus.classList.remove("status-pill-success");
                    metaStatus.classList.add("status-pill-muted");
                }
            };

            if (fileInput) {
                fileInput.addEventListener("change", () => {
                    const file = fileInput.files && fileInput.files[0];
                    if (!file) {
                        return;
                    }

                    fileName.textContent = file.name;
                    sourceNameInput.value = file.name;
                    metaSource.textContent = file.name;
                    fileDropzone.classList.add("has-file");

                    const reader = new FileReader();
                    reader.onload = () => {
                        if (typeof reader.result === "string") {
                            textArea.value = reader.result;
                            updateLineNumbers();
                            parseDocumentMeta();
                        }
                    };

                    reader.readAsText(file);
                });
            }

            textArea.addEventListener("input", () => {
                updateLineNumbers();
                parseDocumentMeta();
            });

            textArea.addEventListener("scroll", () => {
                lineNumbers.scrollTop = textArea.scrollTop;
            });

            clearButton.addEventListener("click", () => {
                window.location.href = "/swagger";
            });

            expandButton.addEventListener("click", () => {
                previewPanel.classList.toggle("is-expanded");
            });

            updateLineNumbers();
            parseDocumentMeta();

            @if (hasPreview)
            {
                <text>
                window.ui = SwaggerUIBundle({
                    dom_id: "#swagger-ui",
                    url: "/swagger/spec/@(Model.PreviewId).json",
                    deepLinking: true,
                    displayRequestDuration: true,
                    docExpansion: "list",
                    filter: true,
                    persistAuthorization: true
                });
                </text>
            }
        })();
    </script>
}
